{
  "rewrites": [
    {
      "source": "/(auth|login|register|dashboard|about)",
      "destination": "/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://url-shortner-eoyu.onrender.com/api/$1"
    },
    {
      "source": "/:slug",
      "destination": "https://url-shortner-eoyu.onrender.com/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}